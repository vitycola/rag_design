ANTHROPIC_API_KEY=your_key_here
VOYAGE_API_KEY=your_key_here

# Embedder provider: voyage | local
EMBEDDER=voyage
EMBEDDER_FALLBACK=true

# Chunking strategy: semantic | fixed
CHUNK_STRATEGY=semantic

CHROMA_PATH=./data/processed/chroma

GENERATION_MODEL=claude-sonnet-4-5
JUDGE_MODEL=claude-haiku-3-5

# Sentence-transformers model for local embeddings
ST_MODEL=all-mpnet-base-v2

# Model used for semantic chunking boundary detection
CHUNK_EMBED_MODEL=all-MiniLM-L6-v2

BREAKPOINT_PERCENTILE=95
TOP_K=5
RETRIEVAL_THRESHOLD=0.0
